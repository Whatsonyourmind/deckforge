# DeckForge Environment Configuration
# Copy to .env and adjust values for your environment.
# All variables are prefixed with DECKFORGE_.

# Database (PostgreSQL via psycopg3)
DECKFORGE_DATABASE_URL=postgresql+psycopg://deckforge:deckforge@localhost:5432/deckforge

# Redis (queue broker, cache, SSE pub/sub)
DECKFORGE_REDIS_URL=redis://localhost:6379/0

# S3-compatible storage (MinIO for local dev, Cloudflare R2 for production)
DECKFORGE_S3_ENDPOINT_URL=http://localhost:9000
DECKFORGE_S3_ACCESS_KEY=minioadmin
DECKFORGE_S3_SECRET_KEY=minioadmin
DECKFORGE_S3_BUCKET=deckforge

# API server
DECKFORGE_API_HOST=0.0.0.0
DECKFORGE_API_PORT=8000

# Environment: development | staging | production
DECKFORGE_DEBUG=true
DECKFORGE_ENVIRONMENT=development
